# TMDB API Key (required)
TMDB_API_KEY=your_api_key_here

# PostgreSQL
POSTGRES_DB=raterr
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_secure_password

# App
RATERR_PORT=8080

# Directories on TrueNAS to persist data
# Change to your actual pool paths, e.g. /mnt/tank/apps/raterr/...
POSTGRES_DATA_DIR=/mnt/your-pool/apps/raterr/postgres

# Docker image (only used with compose.yaml, not compose.build.yaml)
RATERR_IMAGE=ghcr.io/anomalyco/raterr:latest
